rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function isMember(weddingId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/weddings/$(weddingId)/members/$(request.auth.uid));
    }

    function isHost(weddingId) {
      return isAuth() &&
        get(/databases/$(database)/documents/weddings/$(weddingId)/members/$(request.auth.uid)).data.role == 'host';
    }

    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // ── Invite code index ─────────────────────────────────────────────────────
    match /weddingsByCode/{code} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── User index (maps uid → weddingIds) ────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ── Wedding document (config) ─────────────────────────────────────────────
    match /weddings/{weddingId} {
      allow read: if isMember(weddingId);
      allow create: if isAuth();
      allow update: if isHost(weddingId);
      allow delete: if false;

      // ── Members ─────────────────────────────────────────────────────────────
      match /members/{uid} {
        allow read: if isMember(weddingId);
        allow create: if isAuth() && isOwner(uid);
        allow update: if isOwner(uid) || isHost(weddingId);
        allow delete: if isHost(weddingId) || isOwner(uid);
      }

      // ── Posts ────────────────────────────────────────────────────────────────
      match /posts/{postId} {
        allow read: if isMember(weddingId);
        allow create: if isMember(weddingId);
        allow update, delete: if isHost(weddingId);

        match /comments/{commentId} {
          allow read: if isMember(weddingId);
          allow create: if isMember(weddingId);
          allow delete: if isOwner(resource.data.authorId) || isHost(weddingId);
        }

        match /likes/{uid} {
          allow read: if isMember(weddingId);
          allow write: if isOwner(uid) && isMember(weddingId);
        }
      }

      // ── Schedule ─────────────────────────────────────────────────────────────
      match /schedule/{eventId} {
        allow read: if isMember(weddingId);
        allow write: if isHost(weddingId);
      }
    }
  }
}
