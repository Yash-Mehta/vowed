{
  "expo": {
    "name": "Vowed",
    "slug": "our-day",
    "version": "1.3.1",
    "scheme": "vowed",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5C1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vowed.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Vowed uses your camera so you can share photos with your wedding party.",
        "NSPhotoLibraryUsageDescription": "Vowed accesses your photos so you can share them with your wedding party.",
        "NSPhotoLibraryAddUsageDescription": "Vowed saves photos to your library.",
        "NSMicrophoneUsageDescription": "Vowed may access your microphone when recording videos.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vowed.app",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5C1A1A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7A4A3F",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vowed accesses your photos so you can share them with your wedding party.",
          "cameraPermission": "Vowed uses your camera so you can share photos with your wedding party."
        }
      ],
      "expo-media-library",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "./plugins/withCxx20",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4c63513-333e-482d-a5cf-8f33669ab2ff"
      }
    },
    "owner": "yashm16"
  }
}
