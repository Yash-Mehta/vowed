{
  "expo": {
    "name": "Our Day",
    "slug": "our-day",
    "version": "1.0.0",
    "scheme": "ourday",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ourday.app"
    },
    "android": {
      "package": "com.ourday.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6F1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      ["expo-image-picker", { "photosPermission": "Allow Our Day to access your photos." }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
