{
  "expo": {
    "name": "Our Day",
    "slug": "our-day",
    "version": "1.0.0",
    "scheme": "ourday",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ourday.app"
    },
    "android": {
      "package": "com.ourday.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6F1"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Our Day to access your photos."
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4c63513-333e-482d-a5cf-8f33669ab2ff"
      }
    },
    "owner": "yashm16"
  }
}
